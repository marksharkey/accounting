# PrecisionPros Database Credentials
# Copy this file to .env and update with your actual credentials
# DO NOT commit .env to git — it contains passwords!

DB_HOST=localhost
DB_PORT=3306
DB_NAME=precisionpros
DB_USER=ppros
DB_PASSWORD=your_password_here

# Frontend URL for password reset links
# Dev: http://localhost:5174
# Production: https://accounting.precisionpros.com
FRONTEND_URL=https://accounting.precisionpros.com

# QuickBooks Online API (from developer.intuit.com → PP-Accounting app → Keys & credentials → Development)
QBO_CLIENT_ID=your_client_id_here
QBO_CLIENT_SECRET=your_client_secret_here
